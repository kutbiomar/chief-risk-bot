# Local development only. Do not store production secrets in this file.

# Core runtime
DATABASE_URL=sqlite:///./backend/runtime/chiefriskbot.db
SECRET_KEY=replace-with-32-byte-random-value
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8080
SESSION_TTL_DAYS=30
SCHEDULER_ENABLED=false

# Auth mode: local or supabase
AUTH_MODE=local

# Optional integrations
ANTHROPIC_API_KEY=
FRED_API_KEY=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Supabase
# Fill these when AUTH_MODE=supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents
